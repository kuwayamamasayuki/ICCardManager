<Window x:Class="ICCardManager.Views.Dialogs.CardRegistrationModeDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="カード登録方法の選択"
        SizeToContent="Height"
        Width="450"
        MinWidth="380"
        MinHeight="260"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontSize="{DynamicResource BaseFontSize}"
        AutomationProperties.Name="カード登録方法選択ダイアログ"
        AutomationProperties.HelpText="交通系ICカードを新規購入として登録するか、紙の出納簿からの繰越として登録するかを選択します">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- アイコンとメッセージ -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,15">
            <TextBlock Text="🗂" FontSize="{DynamicResource DialogIconFontSize}" VerticalAlignment="Center" Margin="0,0,15,0"/>
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="カード登録方法の選択"
                           FontSize="{DynamicResource LargeFontSize}"
                           FontWeight="Bold"/>
                <TextBlock Text="このカードはどのように登録しますか？"
                           FontSize="{DynamicResource BaseFontSize}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="0,5,0,0"/>
            </StackPanel>
        </StackPanel>

        <!-- オプション1: 新規購入 -->
        <Border Grid.Row="1"
                Background="{DynamicResource NeutralBackgroundBrush}"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,10"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                PreviewMouseLeftButtonDown="NewPurchaseBorder_PreviewMouseLeftButtonDown">
            <StackPanel>
                <RadioButton x:Name="NewPurchaseRadio"
                             GroupName="RegistrationMode"
                             Content="新規購入"
                             FontSize="{DynamicResource BaseFontSize}"
                             FontWeight="Bold"
                             IsChecked="True"
                             Checked="NewPurchaseRadio_Checked"
                             AutomationProperties.Name="新規購入として登録"/>
                <TextBlock Text="新しく購入したカードを登録します"
                           FontSize="{DynamicResource SmallFontSize}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="20,5,0,0"/>

                <!-- 購入日選択（Issue #658） -->
                <StackPanel x:Name="NewPurchaseOptionsPanel" Margin="20,10,0,0" IsEnabled="True">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="購入日:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <DatePicker x:Name="PurchaseDatePicker"
                                    Width="130"
                                    Padding="5"
                                    FontSize="{DynamicResource BaseFontSize}"
                                    AutomationProperties.Name="購入日の選択"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- オプション2: 紙の出納簿からの繰越 -->
        <Border Grid.Row="2"
                Background="{DynamicResource NeutralBackgroundBrush}"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,10"
                BorderBrush="{DynamicResource DividerBrush}"
                BorderThickness="1"
                PreviewMouseLeftButtonDown="CarryoverBorder_PreviewMouseLeftButtonDown">
            <StackPanel>
                <RadioButton x:Name="CarryoverRadio"
                             GroupName="RegistrationMode"
                             Content="紙の出納簿からの繰越"
                             FontSize="{DynamicResource BaseFontSize}"
                             FontWeight="Bold"
                             Checked="CarryoverRadio_Checked"
                             AutomationProperties.Name="紙の出納簿からの繰越として登録"/>
                <TextBlock Text="年度途中から本アプリを使用する場合に選択します"
                           FontSize="{DynamicResource SmallFontSize}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           Margin="20,5,0,0"/>

                <!-- 繰越設定 -->
                <StackPanel x:Name="CarryoverOptionsPanel"
                            Margin="20,10,0,0"
                            IsEnabled="False">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <ComboBox x:Name="CarryoverMonthCombo"
                                  Width="80"
                                  FontSize="{DynamicResource BaseFontSize}"
                                  AutomationProperties.Name="繰越月の選択"/>
                        <TextBlock Text=" から繰越"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="開始ページ:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="StartingPageTextBox"
                                 Width="60"
                                 Text="1"
                                 FontSize="{DynamicResource BaseFontSize}"
                                 TextAlignment="Right"
                                 AutomationProperties.Name="開始ページ番号"/>
                    </StackPanel>

                    <!-- Issue #756: 繰越額入力 -->
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="繰越額:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="CarryoverBalanceTextBox"
                                 Width="120"
                                 Padding="10,6"
                                 FontSize="{DynamicResource BaseFontSize}"
                                 TextAlignment="Right"
                                 AutomationProperties.Name="繰越額"
                                 ToolTip="紙の出納簿の前月末残高を入力してください"/>
                        <TextBlock Text="円"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="※ 紙の出納簿の前月末残高を入力してください"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0"/>

                    <!-- Issue #1215: 紙の出納簿の累計受入・累計払出入力 -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <TextBlock Text="累計受入:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="CarryoverIncomeTotalTextBox"
                                 Width="120"
                                 Text="0"
                                 Padding="10,6"
                                 FontSize="{DynamicResource BaseFontSize}"
                                 TextAlignment="Right"
                                 AutomationProperties.Name="累計受入金額"
                                 ToolTip="紙の出納簿の前月末時点の累計受入金額を入力してください"/>
                        <TextBlock Text="円"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,8,0,0">
                        <TextBlock Text="累計払出:"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="0,0,8,0"/>
                        <TextBox x:Name="CarryoverExpenseTotalTextBox"
                                 Width="120"
                                 Text="0"
                                 Padding="10,6"
                                 FontSize="{DynamicResource BaseFontSize}"
                                 TextAlignment="Right"
                                 AutomationProperties.Name="累計払出金額"
                                 ToolTip="紙の出納簿の前月末時点の累計払出金額を入力してください"/>
                        <TextBlock Text="円"
                                   FontSize="{DynamicResource BaseFontSize}"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                    <TextBlock Text="※ 月次帳票の「累計」欄に加算されます（当該年度のみ）"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource MutedTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </StackPanel>
        </Border>

        <!-- ヒント -->
        <Border Grid.Row="3"
                Background="{DynamicResource ReturnBackgroundBrush}"
                CornerRadius="4"
                Padding="12"
                Margin="0,0,0,10"
                VerticalAlignment="Top">
            <TextBlock TextWrapping="Wrap"
                       FontSize="{DynamicResource SmallFontSize}"
                       Foreground="{DynamicResource InfoTextBrush}">
                <Run Text="💡 ヒント: "/>
                <Run Text="紙の出納簿からの繰越を選択した場合、月途中のデータは後からCSVインポートで取り込むことができます。"/>
                <LineBreak/>
                <Run Text="特に月途中からの導入時は手順が複雑になる場合があります。詳しくは管理者マニュアルの「5.6 利用開始時の交通系ICカード登録（初期導入手順）」をご参照ください。"/>
            </TextBlock>
        </Border>

        <!-- ボタン -->
        <StackPanel Grid.Row="4"
                    Orientation="Horizontal"
                    HorizontalAlignment="Right">
            <Button x:Name="OkButton"
                    Content="OK"
                    MinWidth="100"
                    Height="36"
                    Padding="16,0"
                    Margin="0,0,10,0"
                    FontSize="{DynamicResource BaseFontSize}"
                    FontWeight="Bold"
                    Background="{DynamicResource SuccessActionBrush}"
                    Foreground="{DynamicResource OnPrimaryBrush}"
                    Click="OkButton_Click"
                    IsDefault="True"
                    AutomationProperties.Name="OK"
                    AutomationProperties.HelpText="選択した方法でカードを登録します"/>

            <Button x:Name="CancelButton"
                    Content="キャンセル"
                    MinWidth="120"
                    Height="36"
                    Padding="16,0"
                    FontSize="{DynamicResource BaseFontSize}"
                    IsCancel="True"
                    Click="CancelButton_Click"
                    AutomationProperties.Name="キャンセル"
                    AutomationProperties.HelpText="登録をキャンセルします"/>
        </StackPanel>
    </Grid>
</Window>
