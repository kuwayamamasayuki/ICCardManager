<Window x:Class="ICCardManager.Views.Dialogs.SettingsDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ICCardManager.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:SettingsViewModel}"
        Title="設定"
        Height="820"
        Width="550"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        FontSize="{DynamicResource BaseFontSize}"
        FocusManager.FocusedElement="{Binding ElementName=ToastPositionComboBox}"
        AutomationProperties.Name="設定ダイアログ"
        AutomationProperties.HelpText="アプリケーションの各種設定を変更できます。Escapeキーでキャンセルできます。">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 設定項目 (Issue #453: 並び順を変更) -->
        <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 1. 通知設定 -->
                <!-- Issue #1276: TextBlock → Label + Target でアクセスキーとスクリーンリーダー連携を実装 -->
                <GroupBox Header="通知設定" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="トースト通知の表示位置(_T)"
                               Target="{Binding ElementName=ToastPositionComboBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,10"/>
                        <ComboBox x:Name="ToastPositionComboBox"
                                  ItemsSource="{Binding ToastPositionOptions}"
                                  SelectedItem="{Binding SelectedToastPositionItem}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  AutomationProperties.Name="トースト通知位置選択"
                                  AutomationProperties.HelpText="貸出・返却時の通知が表示される画面の位置を選択します"
                                  ToolTip="右上・左上・右下・左下から選択（アクセスキー: Alt+T）"/>
                        <TextBlock Text="※ 「いってらっしゃい！」「おかえりなさい！」の表示位置"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 2. 表示設定 -->
                <GroupBox Header="表示設定" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="文字サイズ(_F)"
                               Target="{Binding ElementName=FontSizeComboBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,10"/>
                        <ComboBox x:Name="FontSizeComboBox"
                                  ItemsSource="{Binding FontSizeOptions}"
                                  SelectedItem="{Binding SelectedFontSizeItem}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8"
                                  Width="200"
                                  HorizontalAlignment="Left"
                                  AutomationProperties.Name="文字サイズ選択"
                                  AutomationProperties.HelpText="画面に表示される文字のサイズを選択します"
                                  ToolTip="小・中・大・特大から選択（アクセスキー: Alt+F）"/>
                        <TextBlock Text="※ 文字サイズの変更は保存後に反映されます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 3. 残額警告 -->
                <GroupBox Header="残額警告" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="残額警告しきい値(_W)"
                               Target="{Binding ElementName=WarningBalanceTextBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,5"/>
                        <TextBlock Text="残額がこの金額を下回った場合に警告を表示します"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBox x:Name="WarningBalanceTextBox"
                                     Text="{Binding WarningBalance, UpdateSourceTrigger=PropertyChanged}"
                                     Width="120"
                                     Padding="8"
                                     VerticalAlignment="Center"
                                     AutomationProperties.Name="残額警告しきい値"
                                     AutomationProperties.HelpText="この金額を下回ると警告が表示されます"
                                     ToolTip="0～20,000円の範囲で設定（アクセスキー: Alt+W）"/>
                            <TextBlock Text="円"
                                       VerticalAlignment="Center"
                                       Margin="10,0,0,0"/>
                        </StackPanel>
                        <TextBlock Text="※ 0～20,000円の範囲で設定できます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 4. 音声設定 -->
                <GroupBox Header="音声設定" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="貸出・返却時の音声(_O)"
                               Target="{Binding ElementName=SoundModeComboBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,10"/>
                        <ComboBox x:Name="SoundModeComboBox"
                                  ItemsSource="{Binding SoundModeOptions}"
                                  SelectedItem="{Binding SelectedSoundModeItem}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8"
                                  Width="250"
                                  HorizontalAlignment="Left"
                                  AutomationProperties.Name="音声モード選択"
                                  AutomationProperties.HelpText="貸出・返却時に再生される音声を選択します"
                                  ToolTip="効果音・音声（男性/女性）・無しから選択（アクセスキー: Alt+O）"/>
                        <TextBlock Text="※ 音声（男性）:「いってらっしゃい」「おかえりなさい」"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="※ 音声（女性）:「いってらっしゃい」「おかえりなさい」"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                        <TextBlock FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,10,0,0">
                            <Run Text="音声クレジット: VOICEVOX:四国めたん / VOICEVOX:玄野武宏"/>
                        </TextBlock>
                    </StackPanel>
                </GroupBox>

                <!-- 5. 部署設定（Issue #659） -->
                <GroupBox Header="部署設定" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="部署及び支出科目(_P)"
                               Target="{Binding ElementName=DepartmentTypeComboBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,10"/>
                        <ComboBox x:Name="DepartmentTypeComboBox"
                                  ItemsSource="{Binding DepartmentTypeOptions}"
                                  SelectedItem="{Binding SelectedDepartmentTypeItem}"
                                  DisplayMemberPath="DisplayName"
                                  Padding="8"
                                  Width="350"
                                  HorizontalAlignment="Left"
                                  AutomationProperties.Name="部署種別選択"
                                  AutomationProperties.HelpText="部署種別を選択します。チャージ時の摘要と帳票テンプレートが変わります"
                                  ToolTip="市長事務部局（役務費）または企業会計部局（旅費）を選択（アクセスキー: Alt+P）"/>
                        <TextBlock Text="※ チャージ時の摘要と帳票テンプレートが変わります"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="※ 借損料（駐車場代）や自動車借上料（タクシー料金）には対応していません"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 6. 運用設定 -->
                <GroupBox Header="運用設定" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <CheckBox IsChecked="{Binding SkipBusStopInputOnReturn}"
                                  Content="返却時のバス停名入力をスキップする(_K)"
                                  Padding="5,0,0,0"
                                  AutomationProperties.Name="バス停名入力スキップ設定"
                                  AutomationProperties.HelpText="有効にすると、返却時にバス停名入力ダイアログを表示しません"
                                  ToolTip="有効にすると、返却時にバス停名入力ダイアログを表示せず、後から「バス停名未入力一覧」で入力できます（アクセスキー: Alt+K）"/>
                        <TextBlock Text="※ 有効にすると、返却時にバス停名入力ダイアログを表示せず、後から「バス停名未入力一覧」で入力できます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 7. バックアップ -->
                <GroupBox Header="バックアップ" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="データベースの自動バックアップ先フォルダ(_B)"
                               Target="{Binding ElementName=BackupPathTextBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="BackupPathTextBox"
                                     Grid.Column="0"
                                     Text="{Binding BackupPath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     AutomationProperties.Name="バックアップ先フォルダパス"
                                     ToolTip="フォルダパスを直接入力できます（UNCパスも可）（アクセスキー: Alt+B）"/>
                            <Button Grid.Column="1"
                                    Content="参照...(_R)"
                                    Command="{Binding BrowseBackupPathCommand}"
                                    Padding="15,8"
                                    Margin="10,0,0,0"
                                    AutomationProperties.Name="バックアップフォルダを選択"
                                    ToolTip="バックアップ先フォルダを選択します（アクセスキー: Alt+R）"/>
                        </Grid>
                        <TextBlock Text="※ 空欄の場合、アプリケーションフォルダにバックアップされます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,5,0,0"/>
                    </StackPanel>
                </GroupBox>

                <!-- 8. データベース保存先 -->
                <GroupBox Header="データベース保存先" Margin="0,0,0,20" Padding="15">
                    <StackPanel>
                        <Label Content="データベース保存先フォルダ(_D)"
                               Target="{Binding ElementName=DatabasePathTextBox}"
                               FontWeight="Bold"
                               Padding="0"
                               Margin="0,0,0,5"/>
                        <TextBlock Text="データベースの保存先フォルダを指定します。共有フォルダを指定すると、複数のPCから同時に利用できます。"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="DatabasePathTextBox"
                                     Grid.Column="0"
                                     Text="{Binding DatabasePath, UpdateSourceTrigger=PropertyChanged}"
                                     Padding="8"
                                     AutomationProperties.Name="データベース保存先フォルダパス"
                                     ToolTip="共有フォルダのUNCパス（例: \\server\share\ICCardManager）を指定できます。参照ボタンで選択するか、直接入力してください。（アクセスキー: Alt+D）"/>
                            <Button Grid.Column="1"
                                    Content="参照...(_E)"
                                    Command="{Binding BrowseDatabasePathCommand}"
                                    Padding="15,8"
                                    Margin="10,0,0,0"
                                    AutomationProperties.Name="データベース保存先フォルダを選択"
                                    ToolTip="データベース保存先フォルダを選択します（アクセスキー: Alt+E）"/>
                        </Grid>
                        <TextBlock Text="※ 空欄の場合、このPCのローカルフォルダ（C:\ProgramData\ICCardManager\）に保存されます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,5,0,0"/>
                        <TextBlock Text="※ 共有フォルダのパスは「参照」ボタンで選択するか、テキスト欄に直接入力できます"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource SecondaryTextBrush}"
                                   Margin="0,2,0,0"/>
                        <TextBlock Text="※ 変更後はアプリケーションの再起動が必要です"
                                   FontSize="{DynamicResource SmallFontSize}"
                                   Foreground="{DynamicResource DangerTextBrush}"
                                   Visibility="{Binding IsDatabasePathChanged, Converter={StaticResource BoolToVisibilityConverter}}"
                                   FontWeight="Bold"
                                   Margin="0,3,0,0"/>
                    </StackPanel>
                </GroupBox>

            </StackPanel>
        </ScrollViewer>

        <!-- ステータスメッセージとボタン -->
        <StackPanel Grid.Row="1" Margin="0,15,0,0">
            <!-- エラーメッセージ（常に表示領域内） -->
            <TextBlock Text="{Binding StatusMessage}"
                       FontWeight="Bold"
                       TextWrapping="Wrap"
                       Margin="0,0,0,10"
                       AutomationProperties.LiveSetting="Assertive">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        <Setter Property="Visibility" Value="Visible"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding StatusMessage}" Value="{x:Null}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                            </DataTrigger>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- ボタン -->
            <StackPanel Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button Content="キャンセル(_C)"
                        Click="CancelButton_Click"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        MinWidth="100"
                        IsCancel="True"
                        AutomationProperties.Name="キャンセル"
                        AutomationProperties.HelpText="変更を保存せずにダイアログを閉じます"
                        ToolTip="変更を破棄 (Escape / Alt+C)"/>
                <Button Content="保存(_S)"
                        Click="SaveButton_Click"
                        Padding="20,10"
                        MinWidth="100"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        IsDefault="True"
                        AutomationProperties.Name="設定を保存"
                        AutomationProperties.HelpText="変更を保存してダイアログを閉じます"
                        ToolTip="設定を保存 (Enter / Alt+S)"/>
            </StackPanel>
        </StackPanel>

        <!-- 処理中オーバーレイ -->
        <Border Grid.RowSpan="2"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="{Binding BusyMessage}"
                           Foreground="{DynamicResource OnPrimaryBrush}"
                           FontSize="{DynamicResource BaseFontSize}"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
