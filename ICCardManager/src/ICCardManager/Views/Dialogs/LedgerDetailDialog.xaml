<Window x:Class="ICCardManager.Views.Dialogs.LedgerDetailDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ICCardManager.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:LedgerDetailViewModel}"
        Title="利用履歴詳細"
        Height="550"
        Width="850"
        MinHeight="440"
        MinWidth="680"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontSize="{DynamicResource BaseFontSize}"
        AutomationProperties.Name="利用履歴詳細ダイアログ"
        AutomationProperties.HelpText="選択した履歴の詳細を表示・編集します。行の間をクリックして分割線を挿入/削除できます。">

    <Window.InputBindings>
        <!-- Ctrl+S: 保存 -->
        <KeyBinding Key="S" Modifiers="Control" Command="{Binding SaveCommand}"/>
    </Window.InputBindings>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
        <common:StringToVisibilityConverter x:Key="StringToVisibilityConverter" xmlns:common="clr-namespace:ICCardManager.Common"/>

        <!-- グループ行背景色（5色サイクル、淡色） -->
        <SolidColorBrush x:Key="GroupColor0" Color="Transparent"/>
        <SolidColorBrush x:Key="GroupColor1" Color="#E3F2FD"/>
        <SolidColorBrush x:Key="GroupColor2" Color="#E8F5E9"/>
        <SolidColorBrush x:Key="GroupColor3" Color="#FFF3E0"/>
        <SolidColorBrush x:Key="GroupColor4" Color="#F3E5F5"/>
        <SolidColorBrush x:Key="GroupColor5" Color="#FFEBEE"/>

        <!-- グループバッジ色（同サイクル、濃色） Issue #1461 -->
        <SolidColorBrush x:Key="GroupBadgeColor1" Color="#1976D2"/>
        <SolidColorBrush x:Key="GroupBadgeColor2" Color="#388E3C"/>
        <SolidColorBrush x:Key="GroupBadgeColor3" Color="#F57C00"/>
        <SolidColorBrush x:Key="GroupBadgeColor4" Color="#7B1FA2"/>
        <SolidColorBrush x:Key="GroupBadgeColor5" Color="#D32F2F"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- パンくずナビゲーション（Issue #1134） -->
        <TextBlock Grid.Row="0"
                   Text="{Binding BreadcrumbText}"
                   FontSize="{DynamicResource SmallFontSize}"
                   Foreground="{DynamicResource SecondaryTextBrush}"
                   Margin="0,0,0,6"
                   Visibility="{Binding BreadcrumbText, Converter={StaticResource StringToVisibilityConverter}}"
                   AutomationProperties.Name="パンくずナビゲーション"/>

        <!-- 親レコード情報ヘッダー -->
        <Border Grid.Row="1" Background="{DynamicResource ReturnBackgroundBrush}" CornerRadius="4" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- 日付と摘要 -->
                <StackPanel Grid.Row="0" Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="{Binding DateDisplay}"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding SummaryDisplay}"
                               FontSize="{DynamicResource BaseFontSize}"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>

                <!-- 金額情報 -->
                <StackPanel Grid.Row="0" Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="{Binding IncomeDisplay}"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource SuccessActionBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               Visibility="{Binding IncomeDisplay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="{Binding ExpenseDisplay}"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource LendingForegroundBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,15,0"
                               Visibility="{Binding ExpenseDisplay, Converter={StaticResource BoolToVisibilityConverter}}"/>
                    <TextBlock Text="残高:"
                               FontSize="{DynamicResource BaseFontSize}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding BalanceDisplay}"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               Foreground="{DynamicResource InfoTextBrush}"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 利用者と備考 -->
                <StackPanel Grid.Row="1" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,8,0,0">
                    <TextBlock Text="利用者:"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding StaffName}"
                               FontSize="{DynamicResource SmallFontSize}"
                               Margin="5,0,20,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="備考:"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding Note}"
                               FontSize="{DynamicResource SmallFontSize}"
                               Margin="5,0,0,0"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ツールバー -->
        <Border Grid.Row="2" Background="{DynamicResource NeutralBackgroundBrush}" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Orientation="Horizontal">
                    <Button Content="📦 すべて統合"
                            Command="{Binding MergeAllCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            ToolTip="すべての分割線を削除して1つのグループにします"
                            AutomationProperties.Name="すべて統合"/>
                    <Button Content="📤 すべて分割"
                            Command="{Binding SplitAllCommand}"
                            Padding="12,6"
                            Margin="0,0,8,0"
                            ToolTip="すべての行の間に分割線を入れて個別にします"
                            AutomationProperties.Name="すべて分割"/>
                    <Button Content="🔄 自動検出に戻す"
                            Command="{Binding ResetToAutoDetectCommand}"
                            Padding="12,6"
                            ToolTip="すべての分割線を削除し、自動検出モードに戻します"
                            AutomationProperties.Name="自動検出に戻す"/>
                </StackPanel>

                <TextBlock Grid.Column="1"
                           Text="{Binding StatusMessage}"
                           Foreground="{DynamicResource MutedTextBrush}"
                           VerticalAlignment="Center"
                           FontSize="{DynamicResource SmallFontSize}"/>
            </Grid>
        </Border>

        <!-- 詳細一覧（カスタムリスト: 分割線クリック対応） -->
        <Border Grid.Row="3" BorderBrush="{DynamicResource NeutralBorderBrush}" BorderThickness="1" CornerRadius="4">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- ヘッダー行 -->
                <Border Grid.Row="0" Background="{DynamicResource NeutralBackgroundBrush}" Padding="8,6">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="60"/>
                            <ColumnDefinition Width="140"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="90"/>
                            <ColumnDefinition Width="90"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="グループ" FontWeight="SemiBold" FontSize="{DynamicResource SmallFontSize}"/>
                        <TextBlock Grid.Column="1" Text="日時" FontWeight="SemiBold" FontSize="{DynamicResource SmallFontSize}"/>
                        <TextBlock Grid.Column="2" Text="区間" FontWeight="SemiBold" FontSize="{DynamicResource SmallFontSize}"/>
                        <TextBlock Grid.Column="3" Text="金額" FontWeight="SemiBold" FontSize="{DynamicResource SmallFontSize}" HorizontalAlignment="Right"/>
                        <TextBlock Grid.Column="4" Text="残高" FontWeight="SemiBold" FontSize="{DynamicResource SmallFontSize}" HorizontalAlignment="Right"/>
                    </Grid>
                </Border>

                <!-- データ行 -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="DetailsList" ItemsSource="{Binding Items}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <!-- データ行 -->
                                    <Border Padding="8,8" x:Name="DataRowBorder">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="Transparent"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding GroupColorIndex}" Value="1">
                                                        <Setter Property="Background" Value="{StaticResource GroupColor1}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GroupColorIndex}" Value="2">
                                                        <Setter Property="Background" Value="{StaticResource GroupColor2}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GroupColorIndex}" Value="3">
                                                        <Setter Property="Background" Value="{StaticResource GroupColor3}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GroupColorIndex}" Value="4">
                                                        <Setter Property="Background" Value="{StaticResource GroupColor4}"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding GroupColorIndex}" Value="5">
                                                        <Setter Property="Background" Value="{StaticResource GroupColor5}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="60"/>
                                                <ColumnDefinition Width="140"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="90"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- グループバッジ -->
                                            <Border Grid.Column="0" CornerRadius="3" Padding="6,2" HorizontalAlignment="Left" MinWidth="28">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="Transparent"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding GroupColorIndex}" Value="1">
                                                                <Setter Property="Background" Value="{StaticResource GroupBadgeColor1}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding GroupColorIndex}" Value="2">
                                                                <Setter Property="Background" Value="{StaticResource GroupBadgeColor2}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding GroupColorIndex}" Value="3">
                                                                <Setter Property="Background" Value="{StaticResource GroupBadgeColor3}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding GroupColorIndex}" Value="4">
                                                                <Setter Property="Background" Value="{StaticResource GroupBadgeColor4}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding GroupColorIndex}" Value="5">
                                                                <Setter Property="Background" Value="{StaticResource GroupBadgeColor5}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding GroupLabel}"
                                                           HorizontalAlignment="Center"
                                                           FontWeight="Bold"
                                                           FontSize="{DynamicResource SmallFontSize}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding GroupColorIndex}" Value="0">
                                                                    <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Border>

                                            <!-- 日時 -->
                                            <TextBlock Grid.Column="1" Text="{Binding UseDateDisplay}"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource SmallFontSize}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCharge}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 区間 -->
                                            <TextBlock Grid.Column="2" Text="{Binding RouteDisplay}"
                                                       VerticalAlignment="Center"
                                                       TextTrimming="CharacterEllipsis"
                                                       FontSize="{DynamicResource SmallFontSize}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsCharge}" Value="True">
                                                                <Setter Property="FontWeight" Value="Bold"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsBus}" Value="True">
                                                                <Setter Property="FontStyle" Value="Italic"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>

                                            <!-- 金額 -->
                                            <TextBlock Grid.Column="3" Text="{Binding AmountDisplay}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource SmallFontSize}"/>

                                            <!-- 残高 -->
                                            <TextBlock Grid.Column="4" Text="{Binding BalanceDisplay}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center"
                                                       FontSize="{DynamicResource SmallFontSize}"/>
                                        </Grid>
                                    </Border>

                                    <!-- 分割線クリック領域（行の間） -->
                                    <Button Click="DividerButton_Click"
                                            Tag="{Binding Index}"
                                            Cursor="Hand"
                                            AutomationProperties.Name="分割線を切り替え">
                                        <Button.Style>
                                            <Style TargetType="Button">
                                                <Setter Property="Template">
                                                    <Setter.Value>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border x:Name="DividerBorder"
                                                                    Height="8"
                                                                    Background="Transparent"
                                                                    BorderThickness="0">
                                                                <Grid>
                                                                    <!-- 通常の薄い線（ホバー時に表示） -->
                                                                    <Border x:Name="HoverLine"
                                                                            Height="2"
                                                                            Background="{DynamicResource DividerBrush}"
                                                                            Opacity="0"
                                                                            VerticalAlignment="Center"/>
                                                                    <!-- 分割線（表示時） -->
                                                                    <Border x:Name="DividerLine"
                                                                            Height="4"
                                                                            Background="{DynamicResource WaitingForegroundBrush}"
                                                                            VerticalAlignment="Center"
                                                                            Visibility="Collapsed"/>
                                                                    <!-- クリックヒント -->
                                                                    <TextBlock x:Name="HintText"
                                                                               Text="クリックして分割"
                                                                               FontSize="{DynamicResource SmallFontSize}"
                                                                               Foreground="{DynamicResource MutedTextBrush}"
                                                                               HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center"
                                                                               Visibility="Collapsed"/>
                                                                </Grid>
                                                            </Border>
                                                            <ControlTemplate.Triggers>
                                                                <!-- 分割線が表示されている場合 -->
                                                                <DataTrigger Binding="{Binding ShowDividerBelow}" Value="True">
                                                                    <Setter TargetName="DividerLine" Property="Visibility" Value="Visible"/>
                                                                    <Setter TargetName="DividerBorder" Property="Height" Value="12"/>
                                                                </DataTrigger>
                                                                <!-- ホバー時（分割線なし） -->
                                                                <MultiTrigger>
                                                                    <MultiTrigger.Conditions>
                                                                        <Condition Property="IsMouseOver" Value="True"/>
                                                                    </MultiTrigger.Conditions>
                                                                    <Setter TargetName="HoverLine" Property="Opacity" Value="1"/>
                                                                    <Setter TargetName="DividerBorder" Property="Background" Value="{DynamicResource NeutralBackgroundBrush}"/>
                                                                    <Setter TargetName="HintText" Property="Visibility" Value="Visible"/>
                                                                </MultiTrigger>
                                                                <!-- ホバー時（分割線あり） -->
                                                                <MultiDataTrigger>
                                                                    <MultiDataTrigger.Conditions>
                                                                        <Condition Binding="{Binding RelativeSource={RelativeSource Self}, Path=IsMouseOver}" Value="True"/>
                                                                        <Condition Binding="{Binding ShowDividerBelow}" Value="True"/>
                                                                    </MultiDataTrigger.Conditions>
                                                                    <Setter TargetName="HintText" Property="Text" Value="クリックして統合"/>
                                                                    <Setter TargetName="DividerLine" Property="Background" Value="{DynamicResource DangerTextBrush}"/>
                                                                </MultiDataTrigger>
                                                            </ControlTemplate.Triggers>
                                                        </ControlTemplate>
                                                    </Setter.Value>
                                                </Setter>
                                            </Style>
                                        </Button.Style>
                                    </Button>
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <!-- 操作説明 -->
        <Border Grid.Row="4" Background="{DynamicResource WarningBackgroundBrush}" CornerRadius="4" Padding="10" Margin="0,10,0,0">
            <StackPanel>
                <TextBlock TextWrapping="Wrap" FontSize="{DynamicResource SmallFontSize}">
                    <Run FontWeight="Bold">操作方法:</Run>
                    <Run Text=" 行と行の間をクリックして分割線を挿入/削除できます。"/>
                    <LineBreak/>
                    <Run Text="太い線で区切られていない連続した行は、1つの乗り継ぎとして摘要にまとめられます。"/>
                </TextBlock>
                <!-- 複数グループ時の追加説明（Issue #634） -->
                <TextBlock TextWrapping="Wrap"
                           FontSize="{DynamicResource SmallFontSize}"
                           Margin="0,6,0,0"
                           Visibility="{Binding HasMultipleGroups, Converter={StaticResource BoolToVisibilityConverter}}">
                    <Run FontWeight="Bold">保存方法:</Run>
                    <Run Text=" 「別々の履歴に分割」を押すとグループごとに別の履歴レコードが作られます。「摘要のみ更新」を押すと1つの履歴のまま摘要だけが変わります。"/>
                </TextBlock>
            </StackPanel>
        </Border>

        <!-- フッター -->
        <Grid Grid.Row="5" Margin="0,15,0,0">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{Binding DetailCountDisplay}"
                           Foreground="{DynamicResource SecondaryTextBrush}"
                           VerticalAlignment="Center"/>
                <TextBlock Text=" | " Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"
                           Visibility="{Binding HasChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                <TextBlock Text="未保存の変更があります"
                           Foreground="{DynamicResource DangerTextBrush}"
                           FontWeight="Bold"
                           VerticalAlignment="Center"
                           Visibility="{Binding HasChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <!-- 通常保存ボタン（1グループまたはグループなしの場合） -->
                <Button Content="保存 (Ctrl+S)"
                        Command="{Binding SaveCommand}"
                        Padding="15,8"
                        Margin="0,0,10,0"
                        Background="{DynamicResource SuccessActionBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        AutomationProperties.Name="保存"
                        ToolTip="変更を保存します">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Visibility" Value="{Binding HasChanges, Converter={StaticResource BoolToVisibilityConverter}}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMultipleGroups}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
                <!-- 分割保存ボタン群（複数グループの場合）（Issue #634） -->
                <StackPanel Orientation="Horizontal"
                            Visibility="{Binding HasChanges, Converter={StaticResource BoolToVisibilityConverter}}">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasMultipleGroups}" Value="False">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Button Content="別々の履歴に分割"
                            Command="{Binding SaveWithFullSplitCommand}"
                            Padding="15,8"
                            Margin="0,0,6,0"
                            Background="{DynamicResource InfoTextBrush}"
                            Foreground="{DynamicResource OnPrimaryBrush}"
                            AutomationProperties.Name="別々の履歴に分割"
                            ToolTip="グループごとに別の履歴レコードを作成します"/>
                    <Button Content="摘要のみ更新"
                            Command="{Binding SaveCommand}"
                            Padding="15,8"
                            Margin="0,0,10,0"
                            Background="{DynamicResource SuccessActionBrush}"
                            Foreground="{DynamicResource OnPrimaryBrush}"
                            AutomationProperties.Name="摘要のみ更新"
                            ToolTip="1つの履歴レコードのまま摘要を変更します"/>
                </StackPanel>
                <Button Content="閉じる"
                        Click="CloseButton_Click"
                        Padding="20,8"
                        IsCancel="True"
                        AutomationProperties.Name="閉じる"
                        ToolTip="ダイアログを閉じる (Escape)"/>
            </StackPanel>
        </Grid>

        <!-- 処理中オーバーレイ -->
        <Border Grid.RowSpan="6"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"/>
                <TextBlock Text="保存中..."
                           Foreground="{DynamicResource OnPrimaryBrush}"
                           FontSize="{DynamicResource BaseFontSize}"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
