<Window x:Class="ICCardManager.Views.Dialogs.ReportDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ICCardManager.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:ReportViewModel}"
        Title="帳票作成"
        Height="600"
        Width="700"
        MinHeight="480"
        MinWidth="560"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontSize="{DynamicResource BaseFontSize}"
        AutomationProperties.Name="帳票作成ダイアログ"
        AutomationProperties.HelpText="物品出納簿をExcel形式で作成します。対象年月とカードを選択してください。">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- 設定エリア -->
        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- 対象年月 -->
            <GroupBox Grid.Column="0" Header="対象年月" Padding="10" Margin="0,0,10,0"
                      AutomationProperties.Name="対象年月の選択"
                      AutomationProperties.HelpText="帳票作成の対象とする年月を選択します。先月・今月クイック選択またはドロップダウンで任意の年月を指定できます。">
                <StackPanel>
                    <!-- クイック選択ボタン（使用頻度順: 先月 > 今月） -->
                    <!-- Issue #1278: 選択状態をHelpTextで説明し、選択時はNameに「選択中」を付与 -->
                    <StackPanel Orientation="Horizontal">
                        <Button Command="{Binding SelectLastMonthCommand}"
                                Padding="15,6"
                                Margin="0,0,10,0"
                                ToolTip="対象年月を先月に設定">
                            <Button.Content>先月</Button.Content>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ReturnBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="AutomationProperties.Name" Value="先月を選択"/>
                                    <Setter Property="AutomationProperties.HelpText" Value="クリックすると対象年月を先月に切り替えます。現在は未選択です。"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsLastMonthSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="AutomationProperties.Name" Value="先月（選択中）"/>
                                            <Setter Property="AutomationProperties.HelpText" Value="対象年月は先月が選択されています。"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Command="{Binding SelectThisMonthCommand}"
                                Padding="15,6"
                                ToolTip="対象年月を今月に設定">
                            <Button.Content>今月</Button.Content>
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Background" Value="{DynamicResource ReturnBackgroundBrush}"/>
                                    <Setter Property="BorderBrush" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                    <Setter Property="FontWeight" Value="Normal"/>
                                    <Setter Property="AutomationProperties.Name" Value="今月を選択"/>
                                    <Setter Property="AutomationProperties.HelpText" Value="クリックすると対象年月を今月に切り替えます。現在は未選択です。"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsThisMonthSelected}" Value="True">
                                            <Setter Property="Background" Value="{DynamicResource HeaderBackgroundBrush}"/>
                                            <Setter Property="Foreground" Value="{DynamicResource OnPrimaryBrush}"/>
                                            <Setter Property="FontWeight" Value="Bold"/>
                                            <Setter Property="AutomationProperties.Name" Value="今月（選択中）"/>
                                            <Setter Property="AutomationProperties.HelpText" Value="対象年月は今月が選択されています。"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>
                    <!-- 年月選択（その他の月用） -->
                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <ComboBox ItemsSource="{Binding Years}"
                                  SelectedItem="{Binding SelectedYear}"
                                  Width="80"
                                  Padding="8"
                                  AutomationProperties.Name="年選択"
                                  AutomationProperties.HelpText="帳票作成対象の年を選択します。ドロップダウンを開いて年度を選んでください。"
                                  ToolTip="対象年を選択"/>
                        <TextBlock Text="年"
                                   VerticalAlignment="Center"
                                   Margin="5,0,15,0"/>
                        <ComboBox ItemsSource="{Binding Months}"
                                  SelectedItem="{Binding SelectedMonth}"
                                  Width="60"
                                  Padding="8"
                                  AutomationProperties.Name="月選択"
                                  AutomationProperties.HelpText="帳票作成対象の月を選択します。ドロップダウンを開いて月を選んでください。"
                                  ToolTip="対象月を選択"/>
                        <TextBlock Text="月"
                                   VerticalAlignment="Center"
                                   Margin="5,0,0,0"/>
                    </StackPanel>
                </StackPanel>
            </GroupBox>

            <!-- 出力先 -->
            <GroupBox Grid.Column="1" Header="出力先フォルダ" Padding="10"
                      AutomationProperties.Name="出力先フォルダの選択">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Text="{Binding OutputFolder, UpdateSourceTrigger=LostFocus}"
                             Padding="8"
                             AutomationProperties.Name="出力先フォルダパス"
                             ToolTip="フォルダパスを直接入力できます（UNCパスも可）"/>
                    <Button Grid.Column="1"
                            Content="参照"
                            Command="{Binding BrowseOutputFolderCommand}"
                            Padding="10,8"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="出力フォルダを選択"
                            ToolTip="帳票の出力先フォルダを選択"/>
                </Grid>
            </GroupBox>
        </Grid>

        <!-- カード選択 -->
        <GroupBox Grid.Row="1" Header="対象カード" Padding="10"
                  AutomationProperties.Name="帳票作成対象カードの選択">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- 全選択チェックボックス -->
                <CheckBox Grid.Row="0"
                          Content="すべて選択"
                          IsChecked="{Binding IsAllSelected}"
                          Margin="0,0,0,10"
                          AutomationProperties.Name="すべてのカードを選択"
                          AutomationProperties.HelpText="オンにすると一覧中のすべての交通系ICカードが帳票作成の対象になります。オフにすると選択状態が解除されます。"
                          ToolTip="すべてのカードを選択または解除"/>

                <!-- カード一覧 -->
                <!-- Note: チェックボックスで選択を管理するため、ListViewの選択機能は無効化 -->
                <ItemsControl Grid.Row="1"
                              ItemsSource="{Binding Cards}"
                              BorderThickness="1"
                              BorderBrush="{DynamicResource SubtleBorderBrush}"
                              Background="White"
                              AutomationProperties.Name="帳票作成対象カードの一覧"
                              AutomationProperties.HelpText="登録済みの交通系ICカード一覧です。各項目のチェックボックスで帳票作成対象を選択してください。">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <VirtualizingStackPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.Template>
                        <ControlTemplate TargetType="ItemsControl">
                            <Border BorderThickness="{TemplateBinding BorderThickness}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    Background="{TemplateBinding Background}">
                                <ScrollViewer VerticalScrollBarVisibility="Auto"
                                              HorizontalScrollBarVisibility="Disabled">
                                    <ItemsPresenter/>
                                </ScrollViewer>
                            </Border>
                        </ControlTemplate>
                    </ItemsControl.Template>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Padding="5" BorderThickness="0,0,0,1" BorderBrush="{DynamicResource SubtleBorderBrush}">
                                <!-- Issue #1278: 行ごとのチェックボックスにスクリーンリーダー用の読み上げテキストを付与 -->
                                <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay}"
                                          Margin="5"
                                          AutomationProperties.HelpText="選択するとこのカードが帳票作成対象に含まれます。">
                                    <AutomationProperties.Name>
                                        <MultiBinding StringFormat="{}{0} {1} {2}">
                                            <Binding Path="CardType"/>
                                            <Binding Path="CardNumber"/>
                                            <Binding Path="Note"/>
                                        </MultiBinding>
                                    </AutomationProperties.Name>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="{Binding CardType}"
                                                   Width="100"
                                                   FontWeight="Bold"/>
                                        <TextBlock Text="{Binding CardNumber}"
                                                   Width="100"/>
                                        <TextBlock Text="{Binding Note}"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </StackPanel>
                                </CheckBox>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </Grid>
        </GroupBox>

        <!-- 作成結果 -->
        <GroupBox Grid.Row="2" Header="作成結果" Padding="10" Margin="0,15,0,0"
                  Visibility="{Binding CreatedFiles.Count, Converter={StaticResource BoolToVisibilityConverter}}"
                  AutomationProperties.Name="帳票作成結果">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" MaxHeight="120"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <ListBox Grid.Row="0"
                         ItemsSource="{Binding CreatedFiles}"
                         MaxHeight="100"
                         BorderThickness="0"
                         AutomationProperties.Name="作成されたファイル一覧"
                         AutomationProperties.HelpText="帳票作成で出力されたExcelファイルの一覧です。ファイル名をクリックすると既定のアプリで開きます。">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock>
                                <Hyperlink Command="{Binding DataContext.OpenCreatedFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                           CommandParameter="{Binding}">
                                    <Run Text="{Binding Mode=OneWay}"/>
                                </Hyperlink>
                            </TextBlock>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
                <Button Grid.Row="1"
                        Content="出力フォルダを開く"
                        Command="{Binding OpenOutputFolderCommand}"
                        HorizontalAlignment="Left"
                        Padding="15,8"
                        Margin="0,10,0,0"
                        AutomationProperties.Name="出力フォルダを開く"
                        AutomationProperties.HelpText="作成した帳票ファイルが保存されているフォルダをエクスプローラーで開きます。"
                        ToolTip="作成した帳票の出力先フォルダを開く"/>
            </Grid>
        </GroupBox>

        <!-- ボタンエリア -->
        <Grid Grid.Row="3" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- ステータスメッセージ -->
            <!-- Issue #1278: LiveSetting=Assertive でスクリーンリーダーに変化を即時通知 -->
            <TextBlock Grid.Column="0"
                       Text="{Binding StatusMessage}"
                       FontWeight="Bold"
                       VerticalAlignment="Center"
                       AutomationProperties.LiveSetting="Assertive"
                       AutomationProperties.Name="帳票作成ステータス">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource PrimaryBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- ボタン -->
            <StackPanel Grid.Column="1"
                        Orientation="Horizontal">
                <Button Content="閉じる"
                        Click="CloseButton_Click"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        MinWidth="100"
                        IsCancel="True"
                        AutomationProperties.Name="閉じる"
                        AutomationProperties.HelpText="ダイアログを閉じます"
                        ToolTip="ダイアログを閉じる (Escape)"/>
                <Button Content="プレビュー"
                        Command="{Binding PreviewSelectedCommand}"
                        Padding="20,10"
                        Margin="0,0,10,0"
                        MinWidth="100"
                        Background="{DynamicResource HeaderBackgroundBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        AutomationProperties.Name="印刷プレビュー"
                        AutomationProperties.HelpText="選択したカードの帳票をプレビュー表示します"
                        ToolTip="選択したカードの帳票をプレビュー"/>
                <Button Content="作成"
                        Command="{Binding CreateReportCommand}"
                        Padding="20,10"
                        MinWidth="100"
                        Background="{DynamicResource SuccessActionBrush}"
                        Foreground="{DynamicResource OnPrimaryBrush}"
                        AutomationProperties.Name="帳票を作成"
                        AutomationProperties.HelpText="選択したカードの帳票を作成します"
                        ToolTip="帳票を作成"/>
            </StackPanel>
        </Grid>

        <!-- 処理中オーバーレイ -->
        <!-- Issue #1278: 処理中要素にもスクリーンリーダー向け情報を付与 -->
        <Border Grid.RowSpan="4"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                AutomationProperties.Name="処理中オーバーレイ"
                AutomationProperties.HelpText="帳票作成処理の実行中です。完了までお待ちください。">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="{Binding IsIndeterminate}"
                             Value="{Binding ProgressValue}"
                             Maximum="{Binding ProgressMax}"
                             Width="250" Height="20"
                             Foreground="{DynamicResource PrimaryBrush}"
                             AutomationProperties.Name="帳票作成進捗"
                             AutomationProperties.HelpText="帳票作成処理の進行状況を示します。"/>
                <TextBlock Text="{Binding BusyMessage}"
                           Foreground="{DynamicResource OnPrimaryBrush}"
                           FontSize="{DynamicResource BaseFontSize}"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           AutomationProperties.LiveSetting="Polite"
                           AutomationProperties.Name="処理中メッセージ"/>
                <Button Content="キャンセル"
                        Command="{Binding CancelOperationCommand}"
                        Visibility="{Binding CanCancel, Converter={StaticResource BoolToVisibilityConverter}}"
                        Margin="0,10,0,0"
                        Padding="20,5"
                        HorizontalAlignment="Center"
                        AutomationProperties.Name="処理をキャンセル"
                        AutomationProperties.HelpText="実行中の帳票作成処理を中止します。"
                        ToolTip="処理を中止"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
