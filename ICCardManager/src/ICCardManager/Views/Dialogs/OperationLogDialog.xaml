<Window x:Class="ICCardManager.Views.Dialogs.OperationLogDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:ICCardManager.ViewModels"
        mc:Ignorable="d"
        d:DataContext="{d:DesignInstance Type=vm:OperationLogSearchViewModel}"
        Title="操作ログ"
        Height="700"
        Width="1000"
        MinHeight="560"
        MinWidth="800"
        WindowStartupLocation="CenterOwner"
        ResizeMode="CanResize"
        FontSize="{DynamicResource BaseFontSize}"
        AutomationProperties.Name="操作ログダイアログ"
        AutomationProperties.HelpText="システムの操作履歴を検索・表示します。">

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibilityConverter"/>
    </Window.Resources>

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- タイトルヘッダー -->
        <Border Grid.Row="0" Background="{DynamicResource ReturnBackgroundBrush}" CornerRadius="4" Padding="15" Margin="0,0,0,15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#x1F4DD;"
                               FontSize="{DynamicResource LargeFontSize}"
                               VerticalAlignment="Center"
                               Margin="0,0,10,0"/>
                    <TextBlock Text="操作ログ検索"
                               FontSize="{DynamicResource LargeFontSize}"
                               FontWeight="Bold"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="システムで行われた操作の履歴を確認できます"
                               FontSize="{DynamicResource SmallFontSize}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="20,0,0,0"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 検索条件 -->
        <Border Grid.Row="1" BorderBrush="{DynamicResource NeutralBorderBrush}" BorderThickness="1" CornerRadius="4" Padding="15" Margin="0,0,0,10">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- 期間 -->
                <TextBlock Grid.Row="0" Grid.Column="0"
                           Text="期間:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,10"/>
                <StackPanel Grid.Row="0" Grid.Column="1"
                            Orientation="Horizontal"
                            Margin="0,0,20,10">
                    <DatePicker SelectedDate="{Binding FromDate}"
                                Width="120"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="開始日"
                                AutomationProperties.HelpText="検索期間の開始日を選択します。カレンダーから日付を選ぶか、直接入力してください"/>
                    <TextBlock Text="～"
                               VerticalAlignment="Center"
                               Margin="5,0"/>
                    <DatePicker SelectedDate="{Binding ToDate}"
                                Width="120"
                                VerticalAlignment="Center"
                                AutomationProperties.Name="終了日"
                                AutomationProperties.HelpText="検索期間の終了日を選択します。カレンダーから日付を選ぶか、直接入力してください"/>
                    <Button Content="今日"
                            Command="{Binding SetTodayCommand}"
                            Padding="8,4"
                            Margin="10,0,0,0"
                            AutomationProperties.Name="今日の期間に設定"
                            AutomationProperties.HelpText="開始日と終了日を本日に設定して操作ログを検索します"
                            ToolTip="今日の操作ログを表示"/>
                    <Button Content="今月"
                            Command="{Binding SetThisMonthCommand}"
                            Padding="8,4"
                            Margin="5,0,0,0"
                            AutomationProperties.Name="今月の期間に設定"
                            AutomationProperties.HelpText="開始日と終了日を今月の月初・月末に設定して操作ログを検索します"
                            ToolTip="今月の操作ログを表示"/>
                    <Button Content="先月"
                            Command="{Binding SetLastMonthCommand}"
                            Padding="8,4"
                            Margin="5,0,0,0"
                            AutomationProperties.Name="先月の期間に設定"
                            AutomationProperties.HelpText="開始日と終了日を先月の月初・月末に設定して操作ログを検索します"
                            ToolTip="先月の操作ログを表示"/>
                </StackPanel>

                <!-- 操作種別 -->
                <TextBlock Grid.Row="0" Grid.Column="2"
                           Text="操作種別:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,10"/>
                <ComboBox Grid.Row="0" Grid.Column="3"
                          ItemsSource="{Binding ActionTypes}"
                          SelectedItem="{Binding SelectedAction}"
                          DisplayMemberPath="DisplayName"
                          Width="100"
                          Margin="0,0,20,10"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="操作種別"
                          AutomationProperties.HelpText="検索する操作種別（追加・更新・削除など）を選択します。すべてを選ぶと種別による絞り込みは行いません"
                          ToolTip="操作種別で絞り込み（追加・更新・削除など）"/>

                <!-- 対象 -->
                <TextBlock Grid.Row="0" Grid.Column="4"
                           Text="対象:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,10"/>
                <ComboBox Grid.Row="0" Grid.Column="5"
                          ItemsSource="{Binding TargetTables}"
                          SelectedItem="{Binding SelectedTargetTable}"
                          DisplayMemberPath="DisplayName"
                          Width="120"
                          Margin="0,0,0,10"
                          VerticalAlignment="Center"
                          AutomationProperties.Name="対象テーブル"
                          AutomationProperties.HelpText="検索対象とするテーブル（職員・カード・履歴など）を選択します。すべてを選ぶと対象テーブルによる絞り込みは行いません"
                          ToolTip="対象テーブルで絞り込み（職員・カード・履歴など）"/>

                <!-- 対象ID -->
                <TextBlock Grid.Row="1" Grid.Column="0"
                           Text="対象ID:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="1"
                         Text="{Binding TargetIdFilter, UpdateSourceTrigger=PropertyChanged}"
                         Width="200"
                         Padding="5"
                         HorizontalAlignment="Left"
                         Margin="0,0,20,0"
                         AutomationProperties.Name="対象ID"
                         AutomationProperties.HelpText="カードIDmや職員番号などの対象IDで絞り込みます。部分一致で検索されます。空欄にするとIDによる絞り込みは行いません"
                         ToolTip="カードIDmなどの対象IDで絞り込み（部分一致）"/>

                <!-- 操作者名 -->
                <TextBlock Grid.Row="1" Grid.Column="2"
                           Text="操作者名:"
                           VerticalAlignment="Center"
                           Margin="0,0,10,0"/>
                <TextBox Grid.Row="1" Grid.Column="3"
                         Text="{Binding OperatorNameFilter, UpdateSourceTrigger=PropertyChanged}"
                         Width="150"
                         Padding="5"
                         HorizontalAlignment="Left"
                         Margin="0,0,20,0"
                         AutomationProperties.Name="操作者名"
                         AutomationProperties.HelpText="操作を行った職員名で絞り込みます。部分一致で検索されます。空欄にすると操作者による絞り込みは行いません"
                         ToolTip="操作者名で絞り込み（部分一致）"/>

                <!-- 検索ボタン -->
                <StackPanel Grid.Row="1" Grid.Column="4" Grid.ColumnSpan="2"
                            Orientation="Horizontal"
                            HorizontalAlignment="Right">
                    <Button Content="クリア"
                            Command="{Binding ClearFiltersCommand}"
                            Padding="15,6"
                            Margin="0,0,10,0"
                            AutomationProperties.Name="検索条件をクリア"
                            AutomationProperties.HelpText="入力した検索条件をすべてリセットして既定値に戻します"
                            ToolTip="検索条件をクリア"/>
                    <Button Content="検索"
                            Command="{Binding SearchCommand}"
                            Background="{DynamicResource PrimaryBrush}"
                            Foreground="{DynamicResource OnPrimaryBrush}"
                            Padding="20,6"
                            FontWeight="Bold"
                            AutomationProperties.Name="検索を実行"
                            AutomationProperties.HelpText="入力した条件に一致する操作ログを検索して一覧に表示します"
                            ToolTip="条件に一致する操作ログを検索"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- 操作ログ一覧 -->
        <DataGrid x:Name="LogsDataGrid"
                  Grid.Row="2"
                  ItemsSource="{Binding Logs}"
                  SelectedItem="{Binding SelectedLog}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  CanUserAddRows="False"
                  CanUserDeleteRows="False"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  RowHeaderWidth="0"
                  AlternatingRowBackground="{DynamicResource AlternatingRowBrush}"
                  AutomationProperties.Name="操作ログ一覧"
                  AutomationProperties.HelpText="検索条件に一致する操作ログの一覧です。">
            <DataGrid.Columns>
                <DataGridTextColumn Header="日時" Binding="{Binding TimestampDisplay}" Width="150"/>
                <DataGridTextColumn Header="操作" Binding="{Binding ActionDisplay}" Width="60">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding Action}" Value="INSERT">
                                    <Setter Property="Foreground" Value="{DynamicResource SuccessActionBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Action}" Value="UPDATE">
                                    <Setter Property="Foreground" Value="{DynamicResource WarningActionBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding Action}" Value="DELETE">
                                    <Setter Property="Foreground" Value="{DynamicResource ErrorBorderBrush}"/>
                                    <Setter Property="FontWeight" Value="Bold"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
                <DataGridTextColumn Header="対象" Binding="{Binding TargetTableDisplay}" Width="80"/>
                <DataGridTextColumn Header="対象詳細" Binding="{Binding TargetDisplayName}" Width="250"/>
                <DataGridTextColumn Header="操作者" Binding="{Binding OperatorName}" Width="100"/>
                <DataGridTextColumn Header="詳細" Binding="{Binding DetailSummary}" Width="*"/>
            </DataGrid.Columns>

            <!-- 操作種別による行スタイル -->
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Action}" Value="DELETE">
                            <Setter Property="Background" Value="{DynamicResource ErrorBackgroundBrush}"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- ページネーション -->
        <Border Grid.Row="3" Margin="0,10,0,0">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- ページ情報 -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center">
                    <!-- Issue #1468: 動的更新される TextBlock。Name は付けず Text 自体を読み上げ対象にする。 -->
                    <TextBlock Text="{Binding PageInfo}"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               VerticalAlignment="Center"
                               AutomationProperties.HelpText="現在の検索結果のページ情報（表示中の件数と総件数）"
                               AutomationProperties.LiveSetting="Polite"/>
                    <TextBlock Text="  |  表示件数:"
                               Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="10,0,5,0"
                               VerticalAlignment="Center"/>
                    <ComboBox ItemsSource="{Binding PageSizeOptions}"
                              SelectedItem="{Binding PageSize}"
                              Width="60"
                              VerticalAlignment="Center"
                              AutomationProperties.Name="1ページあたりの表示件数"
                              AutomationProperties.HelpText="一覧に1ページあたり表示する操作ログの件数を選択します"
                              ToolTip="1ページあたりの表示件数"/>
                </StackPanel>

                <!-- ページナビゲーション -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Content="&#x23EE;"
                            Command="{Binding FirstPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Width="35"
                            Height="30"
                            AutomationProperties.Name="最初のページへ移動"
                            AutomationProperties.HelpText="検索結果の1ページ目を表示します"
                            ToolTip="最初のページ"/>
                    <Button Content="&#x25C0;"
                            Command="{Binding PreviousPageCommand}"
                            IsEnabled="{Binding HasPreviousPage}"
                            Width="35"
                            Height="30"
                            Margin="5,0,0,0"
                            AutomationProperties.Name="前のページへ移動"
                            AutomationProperties.HelpText="現在表示しているページの1つ前のページを表示します"
                            ToolTip="前のページ"/>
                    <!-- Issue #1468: Run で構成される TextBlock。HelpText で補足し、ページ変更時は LiveSetting で通知。 -->
                    <TextBlock VerticalAlignment="Center" Margin="15,0"
                               AutomationProperties.HelpText="現在表示中のページ番号と総ページ数"
                               AutomationProperties.LiveSetting="Polite">
                        <Run Text="{Binding CurrentPage, Mode=OneWay}"/>
                        <Run Text=" / "/>
                        <Run Text="{Binding TotalPages, Mode=OneWay}"/>
                        <Run Text=" ページ"/>
                    </TextBlock>
                    <Button Content="&#x25B6;"
                            Command="{Binding NextPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Width="35"
                            Height="30"
                            AutomationProperties.Name="次のページへ移動"
                            AutomationProperties.HelpText="現在表示しているページの1つ後のページを表示します"
                            ToolTip="次のページ"/>
                    <Button Content="&#x23ED;"
                            Command="{Binding LastPageCommand}"
                            IsEnabled="{Binding HasNextPage}"
                            Width="35"
                            Height="30"
                            Margin="5,0,0,0"
                            AutomationProperties.Name="最後のページへ移動"
                            AutomationProperties.HelpText="検索結果の最終ページを表示します"
                            ToolTip="最後のページ"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- フッター -->
        <Grid Grid.Row="4" Margin="0,15,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- エクスポートボタン -->
            <StackPanel Grid.Column="0" Orientation="Horizontal">
                <Button Content="Excelエクスポート"
                        Command="{Binding ExportToExcelCommand}"
                        Padding="15,8"
                        AutomationProperties.Name="Excelファイルにエクスポート"
                        AutomationProperties.HelpText="現在の検索条件に一致する操作ログをExcelファイル(.xlsx)として保存します"
                        ToolTip="検索結果をExcelファイルに出力"/>
                <Button Content="開く"
                        Command="{Binding OpenExportedFileCommand}"
                        Padding="10,8"
                        Margin="5,0,0,0"
                        Visibility="{Binding LastExportedFile, Converter={StaticResource BoolToVisibilityConverter}}"
                        AutomationProperties.Name="エクスポートしたファイルを開く"
                        AutomationProperties.HelpText="直前にエクスポートしたExcelファイルを既定のアプリで開きます"
                        ToolTip="出力したExcelファイルを開く"/>
            </StackPanel>

            <!-- ステータスメッセージ -->
            <!-- Issue #1468: 動的更新される TextBlock。Name は付けず Text 自体を読み上げ対象にする。 -->
            <TextBlock Grid.Column="1"
                       Text="{Binding StatusMessage}"
                       VerticalAlignment="Center"
                       Margin="20,0"
                       AutomationProperties.HelpText="操作ログ検索の処理結果や件数を表示します"
                       AutomationProperties.LiveSetting="Polite">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsStatusError}" Value="True">
                                <Setter Property="Foreground" Value="{DynamicResource DangerTextBrush}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            <!-- 閉じるボタン -->
            <Button Grid.Column="2"
                    Content="閉じる"
                    Click="CloseButton_Click"
                    Padding="20,8"
                    IsCancel="True"
                    AutomationProperties.Name="閉じる"
                    AutomationProperties.HelpText="操作ログダイアログを閉じます"
                    ToolTip="ダイアログを閉じる (Escape)"/>
        </Grid>

        <!-- 処理中オーバーレイ -->
        <Border Grid.RowSpan="5"
                Background="{DynamicResource OverlayBrush}"
                Visibility="{Binding IsBusy, Converter={StaticResource BoolToVisibilityConverter}}"
                AutomationProperties.Name="処理中オーバーレイ"
                AutomationProperties.HelpText="操作ログの読み込みまたはエクスポート処理を実行中です。完了までお待ちください">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <ProgressBar IsIndeterminate="True" Width="200" Height="4"
                             AutomationProperties.Name="処理中"
                             AutomationProperties.HelpText="処理が完了するまでお待ちください"/>
                <!-- Issue #1468: 動的更新メッセージ。Name は付けず Text 自体を読み上げ対象にする。 -->
                <TextBlock Text="{Binding BusyMessage}"
                           Foreground="{DynamicResource OnPrimaryBrush}"
                           FontSize="{DynamicResource BaseFontSize}"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           AutomationProperties.HelpText="現在実行中の処理の内容"
                           AutomationProperties.LiveSetting="Polite"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>
