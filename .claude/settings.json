{
  "permissions": {
    "deny": [
      "Bash(git add -A*)",
      "Bash(git add .)",
      "Bash(git push * --force*)",
      "Bash(git push origin main*)",
      "Bash(git push -u origin main*)"
    ]
  },
  "hooks": {
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/hooks/check-doc-sync.sh",
            "timeout": 15
          }
        ]
      }
    ]
  }
}
